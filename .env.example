# ── API ──────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=TumenuYa
VITE_APP_VERSION=1.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
VITE_JWT_STORAGE_KEY=food_app_token
VITE_REFRESH_TOKEN_KEY=food_app_refresh

# ── Maps (order tracking) ─────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Portal base routes ────────────────────────────────────────────────────────
VITE_ADMIN_ROUTE=/admin
VITE_CLIENT_ROUTE=/
VITE_RESTAURANT_ROUTE=/restaurant
